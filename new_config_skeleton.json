{
    "$schema": "https://raw.githubusercontent.com/imperialCHEPI/healthgps/main/schemas/v1/config.json",
    "version": 2,

    "project_requirements": {
        "demographics": {
            "age": "true/false",
            "gender": "true/false",
            "region": "true/false",
            "ethnicity": "true/false",
            "max_age_for_linear_models": "null/an",
            "age" "number.",
            "Eg-" 80,
            75,
            100
        },
        "income": {
            "enabled": "true/false",
            "type": "continuous",
            "or" "categorical",
            "categories": "4",
            "or" "3",
            "(\"NOTE\"": "Working",
            "on" "more",
            "categories" "like",
            5,
            6,
            "or" 10,
            "and" "more)",
            "adjust_to_factors_mean": "true/false",
            "trended": "true/false",
            "income_based_csv_output": "true/false"
        },
        "physical_activity": {
            "enabled": "true/false",
            "type": "continuous",
            "or" "simple",
            "adjust_to_factors_mean": "true/false",
            "trended": "true/false"
        },
        "risk_factors": {
            "adjust_to_factors_mean": "true/false",
            "trended": "true/false"
        },
        "trend": {
            "enabled": "true/false",
            "type": "null",
            "or" "UPF_trend",
            "or" "income_trend"
        },
        "two_stage": {
            "use_logistic": "true/false"
        }
    },

    "data": {
        "source": "https://example.com/your-data/releases/download/v1/data.zip",
        "checksum": "YOUR_SHA256_CHECKSUM",
        "Eg-" "Mahima",
        "will" "provide",
        "this." "Don't worry :)"
    },

    "inputs": {
        "dataset": {
            "name": "YourDataFile.csv",
            "format": "csv",
            "delimiter": ",",
            "encoding": "UTF8",
            "columns": {
                "Gender": "integer",
                "Age": "integer",
                "Age2": "integer",
                "Age3": "integer",
                "Region": "integer",
                "Sector": "integer",
                "Income": "integer",
                "Ethnicity": "integer"
            }
        },
        "settings": {
            "country_code": "XXX",
            "size_fraction": 0.001,
            "age_range": [ 0, 110 ]
        }
    },

    "modelling": {
        "ses_model": {
            "function_name": "normal",
            "function_parameters": [ 0.0, 1.0 ]
        },
        "policy_start_year": "2022/2027/whatever",
        "year" "the",
        "user" "wants",
        "policy" "to",
        "be" "applied",
        "from",
        "risk_factors": [
            {
                "name": "Gender",
                "level": 0,
                "range": [ 0, 1 ]
            },
            {
                "name": "Age",
                "level": 0,
                "range": [ 0, 110 ]
            }
        ],
        "risk_factor_models": {
            "static": "static_model.json",
            "dynamic": "dynamic_model.json"
        },
        "baseline_adjustments": {
            "format": "csv",
            "delimiter": ",",
            "encoding": "ASCII",
            "file_names": {
                "factorsmean_male": "FactorsMean.Male.csv",
                "factorsmean_female": "FactorsMean.Female.csv"
            }
        }
    },

    "running": {
        "seed": [ 123457896 ],
        "start_time": 2020,
        "stop_time": 2030,
        "trial_runs": 1,
        "sync_timeout_ms": 15000,
        "diseases": [ "diabetes", "stroke" ],
        "interventions": {
            "active_type_id": "simple",
            "types": {
                "simple": {
                    "active_period": {
                        "start_time": 2025,
                        "finish_time": null
                    },
                    "impact_type": "absolute",
                    "impacts": []
                }
            }
        }
    },

    "output": {
        "comorbidities": 5,
        "folder": "${HOME}/healthgps/results/your_project",
        "file_name": "HealthGPS_Result_{TIMESTAMP}.json",
        "individual_id_tracking": {
            "enabled": true/false,
            "age_min": 13,
            "age_max": 20,
            "gender": "all", or "female" or "male"
            "regions": [ "region1", "region3" ],
            "ethnicities": [ "ethnicity1" ],
            "risk_factors": [ "BMI", "Weight", "FoodCarbohydrate", "FoodAlcohol", "FoodLegume" ], "NOTE":  You can add more risk factors here
            "years": [ 2024, 2025, 2026 ], "NOTE":  For how many ever years you would like to track the individuals, you can add those years here
            "scenarios": "both" or "baseline" or "intervention"
        }
    }
}
